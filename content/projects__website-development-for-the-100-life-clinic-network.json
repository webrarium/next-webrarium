        "instruments_title": "🧠 Що використвовували?",
        "challenge_txt__i18n__en": {
          "type": "doc",
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "text": "Develop a modern website for the clinic network with easy navigation",
                  "type": "text"
                }
              ]
            },
            {
              "type": "paragraph",
              "content": [
                {
                  "text": "Combine regional offices in a single system",
                  "type": "text"
                }
              ]
            },
            {
              "type": "paragraph",
