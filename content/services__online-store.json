    "body": [
      {
        "_uid": "dbd6c1c3-5810-4324-89e1-b3f7bdf51651",
        "title": "Послуги",
        "component": "service_details",
        "title__i18n__en": "Services",
        "service_details_cards": [
          {
            "_uid": "cecf3d94-3269-4805-9495-80a92bd32299",
            "title": "Консультація та планування",
            "component": "service_details_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Аналіз ваших потреб і цілей. Розробка стратегії для вашого онлайн магазину. Вибір оптимальних платформ і інструментів для вашого бізнесу.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Consultation and Planning",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Analysis of your needs and goals. Development of a strategy for your online store. Selection of the optimal platforms and tools for your business.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "3d56ccb3-4591-4192-8cc5-271dd09867d0",
            "title": "Адаптивний Дизайн ",
            "component": "service_details_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Створення унікального дизайну, що відповідає вашому бренду. Розробка інтуїтивно зрозумілого інтерфейсу для зручного користування. Адаптивний дизайн, що забезпечує коректне відображення на будь-яких пристроях.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Responsive Design",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Creating a unique design that reflects your brand. Developing an intuitive interface for easy navigation. Responsive design that ensures proper display on all devices.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "24210632-c22e-47e1-be01-1066e919e748",
            "title": "Налаштування інтеграцій",
            "component": "service_details_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Налаштування системи управління контентом (CMS). Інтеграція платіжних систем. Налаштування модулів для управління товарами, замовленнями і клієнтами. Інтеграція з системами аналітики для відстеження ефективності вашого магазину.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Integration Setup",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Configuration of the Content Management System (CMS). Integration of payment systems. Setup of modules for managing products, orders, and customers. Integration with analytics systems to monitor the performance of your store.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "48d4a2c3-d313-402f-b7df-40542dc275ac",
            "title": "Оптимізація і SEO",
            "component": "service_details_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Оптимізація сайту для пошукових систем для покращення видимості в інтернеті. Налаштування мета-тегів, ключових слів і контенту для підвищення рейтингів.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Optimization and SEO",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Website optimization for search engines to improve online visibility. Setting up meta tags, keywords, and content to boost rankings.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "24342c3f-8373-4051-a944-5431011dbf4a",
            "title": "Тестування та запуск",
            "component": "service_details_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Перевірка всіх функцій і елементів сайту. Тестування на різних пристроях і браузерах для забезпечення стабільної роботи. Запуск сайту і моніторинг його роботи на початкових етапах.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Testing and Launch",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Checking all functions and elements of the website. Testing on various devices and browsers to ensure stable performance. Launching the site and monitoring its operation during the initial stages.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "80ab4f5c-c55e-45e8-be30-99695e435d44",
            "title": "Підтримка і обслуговування",
            "component": "service_details_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Надання технічної підтримки і обслуговування сайту. Оновлення системи і компонентів за потреби. Рекомендації з покращення і розвитку функціоналу вашого онлайн магазину.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Support and Maintenance",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Providing technical support and site maintenance. Updating systems and components as needed. Offering recommendations for improving and developing the functionality of your online store.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "_uid": "33f21210-a572-4cd1-817e-dcaac702a36a",
        "cards": [
          {
            "_uid": "ff481707-f819-4e19-b4cf-5272a404a863",
            "title": "Зручність для покупців",
            "component": "service_need_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Онлайн-магазини дозволяють покупцям робити покупки з будь-якого місця і в будь-який час, що знижує необхідність фізичного відвідування магазинів і економить час.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Convenience for Customers",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Online stores allow customers to shop from anywhere and at any time, reducing the need for physical store visits and saving time.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "9e5d01bd-7e8e-41eb-a0fe-8ec843350cc3",
            "title": "Зниження витрат",
            "component": "service_need_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Віртуальний магазин зазвичай має менші витрати на оренду приміщення, оплату праці персоналу та інші витрати, пов’язані з фізичними магазинами.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Cost Reduction",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "A virtual store typically has lower expenses for rent, staff salaries, and other costs associated with physical stores.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "cfa786a5-894a-4e88-9332-f1570ac42218",
            "title": "Можливість автоматизації",
            "component": "service_need_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Онлайн-магазини можуть використовувати автоматизовані системи для обробки замовлень, управління запасами і навіть маркетингу, що спрощує операційні процеси.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Automation Capabilities",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Online stores can use automated systems for order processing, inventory management, and even marketing, simplifying operational processes.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "63680e9f-3c9f-4d2c-8648-5e91d6b271a6",
            "title": "Маркетингові можливості",
            "component": "service_need_card",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Інтернет дозволяє використовувати різні канали для просування товарів, включаючи соціальні мережі, SEO (пошукову оптимізацію), контекстну рекламу та електронну пошту.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Marketing Opportunities",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Allows for the use of various channels to promote products, including social media, SEO (search engine optimization), pay-per-click advertising, and email marketing.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          }
        ],
        "media": "",
        "title": "Навіщо будувати online магазин?",
