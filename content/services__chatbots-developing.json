      {
        "_uid": "f30390bb-3e3d-4609-ade1-005fbbe6be9f",
        "component": "service_details",
        "title": "Часті запитання",
        "title__i18n__en": "Frequently Asked Questions",
        "service_details_cards": [
          {
            "_uid": "bae4e8f9-b75a-48af-b4c6-17f6af765106",
            "component": "service_details_card",
            "title": "Скільки коштує розробка чат-бота?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Вартість залежить від складності логіки, інтеграцій та платформи. Кожен проєкт розраховується індивідуально — залиште заявку для консультації.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "How much does chatbot development cost?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "The cost depends on the complexity of logic, integrations, and platform. Each project is calculated individually — leave a request for a consultation.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "07e09448-9865-4e8c-8412-d1d3e943ee9c",
            "component": "service_details_card",
            "title": "Які платформи підтримуєте?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Telegram, Viber, Instagram, Facebook Messenger та вебсайти. Також інтегруємо з CRM, Google Sheets та іншими сервісами.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "What platforms do you support?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Telegram, Viber, Instagram, Facebook Messenger and websites. We also integrate with CRM, Google Sheets and other services.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "6d36d1e1-7cb2-487d-a2ec-0a6a1a4b13b5",
            "component": "service_details_card",
            "title": "Чи потрібні технічні знання для управління ботом?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Ні. Ми розробляємо зручні інструменти для управління контентом бота без технічних знань та надаємо навчання після здачі проєкту.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "Are technical skills needed to manage the bot?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "No. We develop user-friendly tools to manage bot content without technical knowledge and provide training after project delivery.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "b944a880-e1e5-4a84-a2f0-5f08c0a83be5",
            "component": "service_details_card",
            "title": "Скільки часу займає розробка чат-бота?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Простий чат-бот — 1–2 тижні. Складний бот з інтеграціями та кастомною логікою — 3–6 тижнів.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "How long does chatbot development take?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "A simple chatbot takes 1–2 weeks. A complex bot with integrations and custom logic takes 3–6 weeks.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "_uid": "fae65640-c154-4140-be8e-7a7fcb4fca5c",
        "component": "service_faq",
        "title": "Часті запитання про розробку чат-ботів",
        "title__i18n__en": "FAQ: Chatbot Development",
        "items": [
          {
            "_uid": "ecf51319-1e8e-4d58-9ad8-d8bfac33a1b7",
            "component": "faq_item",
            "question": "На яких платформах ви розробляєте ботів?",
            "answer": "Telegram, Viber, Instagram, Facebook Messenger та WhatsApp. Також можемо інтегрувати бота на ваш сайт через chat-widget.",
            "question__i18n__en": "Which platforms do you build bots for?",
            "answer__i18n__en": "Telegram, Viber, Instagram, Facebook Messenger, and WhatsApp. We can also embed a chat widget on your website."
          },
          {
            "_uid": "5aa8baff-1805-44ae-bc1a-69d28a7cd877",
            "component": "faq_item",
            "question": "Чи може бот приймати оплату?",
            "answer": "Так. Інтегруємо Telegram Pay, LiqPay, Wayforpay та Stripe прямо у чат-бота, щоб клієнти оплачували без виходу з месенджера.",
            "question__i18n__en": "Can a bot accept payments?",
            "answer__i18n__en": "Yes. We integrate Telegram Pay, LiqPay, Wayforpay, and Stripe directly into the chatbot so customers can pay without leaving the messenger."
          },
          {
            "_uid": "3236e71d-e470-4e46-8554-2b2c7b18a972",
            "component": "faq_item",
            "question": "Скільки часу займає розробка чат-бота?",
            "answer": "Простий бот з FAQ та зв'язком з оператором — 1–2 тижні. Складний бот з інтеграціями CRM, оплатою та воронками продажів — 3–6 тижнів.",
            "question__i18n__en": "How long does chatbot development take?",
            "answer__i18n__en": "A simple bot with FAQ and operator handoff takes 1–2 weeks. A complex bot with CRM integrations, payments, and sales funnels takes 3–6 weeks."
          },
          {
            "_uid": "f1252dd7-592f-49c0-a061-e1fe269b43dd",
            "component": "faq_item",
            "question": "Чи можна підключити бота до CRM?",
            "answer": "Так. Інтегруємо з amoCRM, Bitrix24, HubSpot та іншими системами. Усі ліди автоматично потрапляють у вашу базу клієнтів.",
            "question__i18n__en": "Can the bot be connected to a CRM?",
            "answer__i18n__en": "Yes. We integrate with amoCRM, Bitrix24, HubSpot, and other systems. All leads are automatically added to your customer database."
          }
        ]
      }
