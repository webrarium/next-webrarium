            "instruments_list__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Zapier - A cloud-based no-code platform for creating automations between popular services (Google Sheets, Gmail, Shopify, Slack, CRM, etc.).",
                      "type": "text"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "n8n - Flexible open-source low-code platform for building more complex automations. You can install it on your own server and not depend on the cloud.",
