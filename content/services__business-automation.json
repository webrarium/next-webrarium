      {
        "_uid": "81dfdfc4-da0b-440b-ba72-9acc98f5c3cb",
        "component": "service_details",
        "title": "Часті запитання",
        "title__i18n__en": "Frequently Asked Questions",
        "service_details_cards": [
          {
            "_uid": "6ec4ca7b-c552-41f2-bbd9-07e975961dd1",
            "component": "service_details_card",
            "title": "Скільки коштує автоматизація бізнес-процесів?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Вартість залежить від кількості та складності процесів та інтеграцій. Розраховуємо індивідуально — залиште заявку для безкоштовного аналізу.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "How much does business process automation cost?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "The cost depends on the number and complexity of processes and integrations. We calculate individually — leave a request for a free analysis.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "ae3f88f4-05da-4899-a3ee-f0d04c351fa9",
            "component": "service_details_card",
            "title": "Які інструменти використовуєте?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Make (Integromat), Zapier, n8n та кастомні рішення. Вибір інструменту залежить від ваших процесів та бюджету.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "What tools do you use?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Make (Integromat), Zapier, n8n and custom solutions. The tool choice depends on your processes and budget.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "2e6f5704-d15d-46df-a75d-4f199c6961c1",
            "component": "service_details_card",
            "title": "Які процеси можна автоматизувати?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Обробка заявок, синхронізація даних, розсилки, звіти, виставлення рахунків, управління задачами, сповіщення — практично будь-які повторювані операції.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "What processes can be automated?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Lead processing, data synchronization, newsletters, reports, invoicing, task management, notifications — virtually any repetitive operations.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          },
          {
            "_uid": "b0b7b142-f4b7-49dd-9720-026b90cb0658",
            "component": "service_details_card",
            "title": "Скільки часу займає впровадження?",
            "description": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Прості інтеграції налаштовуються за 1–2 тижні. Комплексна автоматизація кількох відділів — 1–2 місяці.",
                      "type": "text"
                    }
                  ]
                }
              ]
            },
            "title__i18n__en": "How long does implementation take?",
            "description__i18n__en": {
              "type": "doc",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "text": "Simple integrations are set up in 1–2 weeks. Comprehensive automation of multiple departments takes 1–2 months.",
                      "type": "text"
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "_uid": "2f932202-57e8-4032-9dc4-ef571ec84522",
        "component": "service_faq",
        "title": "Часті запитання про автоматизацію бізнесу",
        "title__i18n__en": "FAQ: Business Process Automation",
        "items": [
          {
            "_uid": "41f81e5f-2f25-4a0c-90b5-903b24df6dc3",
            "component": "faq_item",
            "question": "Які інструменти ви використовуєте для автоматизації?",
            "answer": "Ми працюємо з Make (Integromat), Zapier, n8n, Airtable та іншими no-code/low-code рішеннями. Вибір інструменту залежить від задачі та бюджету.",
            "question__i18n__en": "What tools do you use for automation?",
            "answer__i18n__en": "We work with Make (Integromat), Zapier, n8n, Airtable, and other no-code/low-code solutions. The choice of tool depends on the task and budget."
          },
          {
            "_uid": "33effcb0-033b-48fb-9a91-81606d7fb625",
            "component": "faq_item",
            "question": "Що можна автоматизувати?",
            "answer": "Обробку лідів і заявок, email-розсилки, синхронізацію даних між системами, звіти, нагадування, виставлення рахунків та сотні інших рутинних процесів.",
            "question__i18n__en": "What can be automated?",
            "answer__i18n__en": "Lead and request processing, email campaigns, data sync between systems, reports, reminders, invoicing, and hundreds of other routine processes."
          },
          {
            "_uid": "25328a08-041f-4f74-9b95-63d10a61a347",
            "component": "faq_item",
            "question": "Чи потрібні технічні знання для управління автоматизацією?",
            "answer": "Ні. Ми налаштовуємо всі сценарії та навчаємо вашу команду. Після запуску ви зможете вносити базові зміни самостійно без коду.",
            "question__i18n__en": "Do I need technical knowledge to manage automation?",
            "answer__i18n__en": "No. We configure all workflows and train your team. After launch, you can make basic changes independently without any code."
          },
          {
            "_uid": "805006dc-cf1a-4f58-ac5f-39115ff20671",
            "component": "faq_item",
            "question": "Як швидко окупається автоматизація?",
            "answer": "Більшість клієнтів бачать окупність за 1–3 місяці. Економія часу і зменшення помилок перевищують витрати на налаштування вже в перші тижні.",
            "question__i18n__en": "How quickly does automation pay off?",
            "answer__i18n__en": "Most clients see ROI within 1–3 months. Time savings and reduced errors outweigh setup costs within the first few weeks."
          }
        ]
      }
    ],
